# ==========================================
# 1. 平台与设备 (专供京东云亚瑟单编)
# ==========================================
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y

# 剔除其他设备 (极简加速)
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_cmiot_ax18=n
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=n
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_linksys_mr7350=n
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_qihoo_360v6=n
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud=n
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5=n
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_xiaomi_ax1800=n
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=n

# ==========================================
# 2. 分区大小 (2GB 满血大分区)
# ==========================================
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=2048

# ==========================================
# 3. 核心 Wi-Fi 驱动与 NSS 硬件加速
# ==========================================
CONFIG_DRIVER_11AC_SUPPORT=y
CONFIG_DRIVER_11AX_SUPPORT=y
CONFIG_PACKAGE_hostapd-common=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_kmod-ath=y
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_kmod-ath11k-pci=y
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-mac80211=y
CONFIG_PACKAGE_wifi-scripts=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_wpad-openssl=y

# 亚瑟专属固件与射频校准文件
CONFIG_PACKAGE_ath11k-firmware-ipq6018=y
CONFIG_PACKAGE_ipq-wifi-jdcloud_re-ss-01=y

# 高通 NSS 与 1G 内存防爆优化
CONFIG_ATH11K_NSS_SUPPORT=y
CONFIG_NSS_DRV_WIFI_EXT_VDEV_ENABLE=y
CONFIG_IPQ_MEM_PROFILE_1024=y
CONFIG_ATH11K_MEM_PROFILE_1G=y
CONFIG_PACKAGE_sqm-scripts-nss=y
CONFIG_PACKAGE_kmod-qca-nss-crypto=y

# ==========================================
# 4. 内核高级配置 (⚠️ 注意：极其占用内核空间，不玩 Docker 建议全部改成 =n 或删掉)
# ==========================================
CONFIG_KERNEL_ARM_PMU=n
CONFIG_KERNEL_CFQ_GROUP_IOSCHED=n
CONFIG_KERNEL_CGROUP_DEVICE=n
CONFIG_KERNEL_CGROUP_FREEZER=n
CONFIG_KERNEL_CGROUP_HUGETLB=n
CONFIG_KERNEL_CGROUP_NET_PRIO=n
CONFIG_KERNEL_CGROUP_PERF=n
CONFIG_KERNEL_HUGETLBFS=n
CONFIG_KERNEL_HUGETLB_PAGE=n
CONFIG_KERNEL_MEMCG_SWAP_ENABLED=n
CONFIG_KERNEL_NET_CLS_CGROUP=n
CONFIG_KERNEL_PERF_EVENTS=n

# ==========================================
# 5. 核心科学、网络代理与所有插件 (全部加回！)
# ==========================================
CONFIG_PACKAGE_luci-app-dae=y
CONFIG_PACKAGE_luci-i18n-dae-zh-cn=y

CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-i18n-nikki-zh-cn=y

CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_luci-i18n-tailscale-zh-cn=y

CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y

CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y

CONFIG_PACKAGE_luci-app-wolplus=y
CONFIG_PACKAGE_luci-i18n-wolplus-zh-cn=y

CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-i18n-vlmcsd-zh-cn=y

CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-i18n-cpufreq-zh-cn=y

# 预留给未来可能需要的容器
#CONFIG_PACKAGE_luci-app-dockerman=y
#CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y

CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y

# ==========================================
# 6. 语言包与所有多主题合集 (全部加回！)
# ==========================================
# 基础中文语言包（必带，否则后台变英文）
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# -- Argon 主题 --
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

# -- Aurora 主题 --
CONFIG_PACKAGE_luci-theme-aurora=y
CONFIG_PACKAGE_luci-app-aurora-config=y
CONFIG_PACKAGE_luci-i18n-aurora-config-zh-cn=y

# -- Kucat 主题 --
CONFIG_PACKAGE_luci-theme-kucat=y
CONFIG_PACKAGE_luci-app-kucat-config=y
CONFIG_PACKAGE_luci-i18n-kucat-config-zh-cn=y
