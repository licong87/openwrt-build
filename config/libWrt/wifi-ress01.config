CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-07=n
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=n
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=n

# ==========================================
# 无线驱动与底层固件 (完美融合优化版)
# ==========================================

# --- 内存优化 (保留你的原版精髓，防爆内存必备) ---
CONFIG_ATH11K_MEM_PROFILE_1G=y

# --- 核心 Wi-Fi 协议与底层驱动库 ---
CONFIG_DRIVER_11AC_SUPPORT=y
CONFIG_DRIVER_11AX_SUPPORT=y
CONFIG_PACKAGE_kmod-ath=y
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-mac80211=y
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_kmod-ath11k-pci=y

# --- 高通 NSS 硬件加速 (满血核心！大幅提升吞吐量，降低 CPU 占用) ---
CONFIG_ATH11K_NSS_SUPPORT=y
CONFIG_NSS_DRV_WIFI_EXT_VDEV_ENABLE=y

# --- Wi-Fi 固件与安全加密组件 ---
CONFIG_PACKAGE_ath11k-firmware-ipq6018=y
CONFIG_PACKAGE_hostapd-common=y
CONFIG_PACKAGE_wireless-regdb=y
# 启用 WPA3 及高级加密
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_wpad-basic-mbedtls=n
CONFIG_PACKAGE_wpad-basic-wolfssl=n

# --- 无线状态管理与辅助工具 (LuCI 界面显示 Wi-Fi 状态必备) ---
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_wifi-scripts=y

# --- 专属无线校准文件 (严格单选，剔除其他型号) ---
CONFIG_PACKAGE_ipq-wifi-jdcloud_re-ss-01=y

## 防火墙
CONFIG_PACKAGE_firewall=n
CONFIG_PACKAGE_firewall4=y

## 插件
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-ddns-go=n
CONFIG_PACKAGE_luci-app-diskman=n
CONFIG_PACKAGE_luci-app-msd_lite=n
CONFIG_PACKAGE_luci-app-natmap=n
CONFIG_PACKAGE_luci-app-homeproxy=n
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-app-passwall2=y
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Haproxy is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Client is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Server is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Simple_Obfs is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Trojan_Plus is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_V2ray_Geoview is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_V2ray_Plugin is not set
CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_luci-app-smartdns=n
CONFIG_PACKAGE_luci-app-uhttpd=n
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-watchcat=n
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-proto-wireguard=n
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y
CONFIG_PACKAGE_luci-i18n-tailscale=y

## 组件调整
CONFIG_PACKAGE_qrencode=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_coremark=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_ip-full=y
