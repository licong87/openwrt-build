# =========================================================
#             ⚙️ OpenWrt X86 专属定制编译配置单
# =========================================================

# ---------------------------------------------------------
# 1. 核心架构与系统平台 (X86_64)
# ---------------------------------------------------------
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# ---------------------------------------------------------
# 2. 固件镜像与分区设置 (完美适配 PVE 虚拟机)
# ---------------------------------------------------------
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_VMDK_IMAGES=y
CONFIG_TARGET_KERNEL_PARTSIZE=128
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# ---------------------------------------------------------
# 3. 核心防火墙与底层网络组件
# ---------------------------------------------------------
CONFIG_PACKAGE_firewall=n
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_ip-full=y

# ==========================================
# 4.1 内核 eBPF 支持 (x86 空间大，满血开启 BTF)
# ==========================================
CONFIG_KERNEL_BPF_EVENTS=y
CONFIG_KERNEL_CGROUP_BPF=y
CONFIG_KERNEL_BPF_STREAM_PARSER=y
CONFIG_KERNEL_XDP_SOCKETS=y

# ⬇️ x86 专享：满血开启 BTF，释放 dae 完整性能 ⬇️
CONFIG_KERNEL_DEBUG_INFO=y
CONFIG_KERNEL_DEBUG_INFO_BTF=y
CONFIG_PACKAGE_kmod-btf=y

# ---------------------------------------------------------
# 5. 系统实用工具
# ---------------------------------------------------------
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_coremark=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_qrencode=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_opkg=y

# ---------------------------------------------------------
# 6. 网络代理与路由规则 (主理财工具)
# ---------------------------------------------------------
# -- Geodata 规则库 --
CONFIG_PACKAGE_v2ray-geodata=y
CONFIG_PACKAGE_v2ray-geodata-updater=y

# -- 启用的代理工具 --
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-i18n-nikki-zh-cn=y
CONFIG_PACKAGE_luci-app-dae=y
CONFIG_PACKAGE_luci-i18n-dae-zh-cn=y

# -- 禁用的代理工具 (防冲突) --
CONFIG_PACKAGE_luci-app-passwall=n
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Client=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Server=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Simple_Obfs=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Geoview=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=n

CONFIG_PACKAGE_luci-app-passwall2=n
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=n
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Haproxy=n
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Client=n
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Server=n
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Simple_Obfs=n
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_SingBox=n
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_V2ray_Geoview=n
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_V2ray_Plugin=n
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Xray=n

# ---------------------------------------------------------
# 7. 异地组网、穿透与局域网服务
# ---------------------------------------------------------
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-i18n-vlmcsd-zh-cn=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y

# -- 禁用的穿透/网络服务 --
CONFIG_PACKAGE_luci-proto-wireguard=n
CONFIG_PACKAGE_luci-app-ddns-go=n
CONFIG_PACKAGE_luci-app-natmap=n
CONFIG_PACKAGE_luci-app-smartdns=n

# ---------------------------------------------------------
# 8. 路由器系统管理与辅助插件
# ---------------------------------------------------------
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-cpufreq=y


# -- 禁用的辅助插件 --
CONFIG_PACKAGE_luci-app-diskman=n
CONFIG_PACKAGE_luci-app-msd_lite=n
CONFIG_PACKAGE_luci-app-uhttpd=n
CONFIG_PACKAGE_luci-app-watchcat=n
# 明确拒绝 rclone 及其附加面板，防止官方默认强塞
CONFIG_PACKAGE_luci-app-rclone=n
CONFIG_PACKAGE_rclone=n
CONFIG_PACKAGE_luci-app-rclone_INCLUDE_rclone-webui=n
CONFIG_PACKAGE_luci-app-rclone_INCLUDE_rclone-ng=n

# ---------------------------------------------------------
# 9. 界面主题与全局语言支持
# ---------------------------------------------------------
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# -- Argon 主题 --
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

# -- Kucat 主题 --
CONFIG_PACKAGE_luci-theme-kucat=y
CONFIG_PACKAGE_luci-app-kucat-config=y
CONFIG_PACKAGE_luci-i18n-kucat-config-zh-cn=y
